{
    "name": "Nahida Extension",
    "description": "나히다 데스크탑과 연결해 사용할 수 있는 확장 프로그램",
    "version": "3.0.1",
    "manifest_version": 3,
    "permissions": [
        "scripting"
    ],
    "host_permissions": [
        "https://gamebanana.com/*",
        "https://*.gamebanana.com/*",
        "https://api.nahida.live/*",
        "http://localhost:1027/*",
        "http://174.136.207.5/*",
        "https://cloudreve.huihui123.org/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://gamebanana.com/*",
                "https://*.gamebanana.com/*"
            ],
            "js": [
                "src/content/gamebanana/index.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "http://174.136.207.5/*",
                "https://cloudreve.huihui123.org/*"
            ],
            "js": [
                "src/content/hui/xhr.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}